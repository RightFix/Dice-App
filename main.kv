#:import RoundedButton main.RoundedButton

ScreenManager:
    Screen1
    Screen2

<Screen1>:
    name: "single_dice"
    BoxLayout:
        orientation: "vertical"
        padding: 20
        spacing: 20

        RoundedButton:
            text: "Double Dice"
            size_hint_y: .1
            on_release:
                app.root.current = "double_dice"

        Label:
            id: single
            text: "Dice One"
            font_size: 30
            halign: "center"
            size_hint_y: 0.7

        RoundedButton:
            text: "Roll"
            pos_hint: {"center_x": 0.5, "center_y": 0.5}
            size_hint: 0.5, 0.2
            on_release:
                single.text = f"Dice one \n \n {app.ran(1,6)}"

<Screen2>:
    name: "double_dice"
    BoxLayout:
        orientation: "vertical"
        padding: 20
        spacing: 20

        RoundedButton:
            text: "Single Dice"
            size_hint_y: 0.1
            on_release:
                app.root.current = "single_dice"

        Label:
            id: double
            text: "Double Dice"
            font_size: 30
            halign: "center"
            size_hint_y: 0.7

        RoundedButton:
            text: "Roll"
            pos_hint: {"center_x": 0.5, "center_y": 0.5}
            size_hint: 0.5, 0.2
            on_release:
                double.text = f"Double Dice \n\n {app.ran(1,6)}  &  {app.ran(1,6)}"